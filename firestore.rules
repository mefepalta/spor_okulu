rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && role() == "admin";
    }

    function isCoach() {
      return isSignedIn() && role() == "coach";
    }

    function isViewer() {
      return isSignedIn() && role() == "viewer";
    }

    function isParent() {
      return isSignedIn() && role() == "veli";
    }

    function isStudent() {
      return isSignedIn() && role() == "ogrenci";
    }

    // Kendi (eşlenmiş) öğrenci kaydına scope'lu roller: veli + öğrenci. İkisi de
    // 'studentIds' ile eşlenir; bu yüzden aynı okuma yolları paylaşılır.
    function isLinkedToStudents() {
      return isParent() || isStudent();
    }

    function isAdminOrCoach() {
      return isAdmin() || isCoach();
    }

    // Personel = uygulamanın kadro/operasyon verisini okuyabilenler.
    function isStaff() {
      return isAdmin() || isCoach() || isViewer();
    }

    // Giriş yapan veliye atanmış öğrenci kimlikleri (yoksa boş liste).
    function ownStudentIds() {
      let userData =
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userData.keys().hasAny(['studentIds']) && userData.studentIds is list
          ? userData.studentIds
          : [];
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == "viewer";
      // Admin her alanı güncelleyebilir. Kullanıcı ise yalnızca KENDİ belgesinde
      // ve yalnızca profil alanlarını (ad/telefon/foto) değiştirebilir; rol veya
      // studentIds gibi yetki alanlarına dokunamaz (ayrıcalık yükseltmesi engeli).
      allow update: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == userId
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['displayName', 'phone', 'photoBase64', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // Öğrenciler: personel hepsini; veli/öğrenci yalnızca eşlendiği kaydı okur.
    match /students/{studentId} {
      allow read: if isStaff()
        || (isLinkedToStudents() && studentId in ownStudentIds());
      allow write: if isAdmin();
    }

    match /coaches/{document} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Gruplar: antrenör oluşturup düzenleyebilir; silmek yalnızca admin.
    match /groups/{document} {
      allow read: if isStaff();
      allow create, update: if isAdminOrCoach();
      allow delete: if isAdmin();
    }

    // Ödemeler: admin/antrenör hepsini; veli yalnızca kendi çocuğununkini.
    match /payments/{document} {
      allow read: if isAdminOrCoach()
        || (isParent()
            && resource.data.keys().hasAny(['studentId'])
            && resource.data.studentId in ownStudentIds());
      allow write: if isAdmin();
    }

    // Yoklama: personel hepsini; veli/öğrenci yalnızca kendini içeren kayıtları.
    match /attendanceRecords/{document} {
      allow read: if isStaff()
        || (isLinkedToStudents()
            && resource.data.keys().hasAny(['studentIds'])
            && resource.data.studentIds.hasAny(ownStudentIds()));
      allow write: if isAdminOrCoach();
    }

    // Duyuruları herkes (veliler dahil) okuyabilir; personel yazar.
    match /announcements/{document} {
      allow read: if isSignedIn();
      allow write: if isAdminOrCoach();
    }

    // Performans: personel hepsini; veli/öğrenci yalnızca kendi kaydını okur.
    match /performanceRecords/{document} {
      allow read: if isStaff()
        || (isLinkedToStudents() && resource.data.studentId in ownStudentIds());
      allow write: if isAdminOrCoach();
    }

    // Etkinlikleri herkes okuyabilir; personel planlar.
    match /plannedEvents/{document} {
      allow read: if isSignedIn();
      allow write: if isAdminOrCoach();
    }

    // Katılım cevapları: personel hepsini; veli yalnızca kendi cevaplarını
    // okur. Veli yazarken cevabın kendi UID'siyle ve kendi çocuğu için
    // olduğunu doğrularız.
    match /eventResponses/{document} {
      allow read: if isStaff()
        || (isParent() && resource.data.parentUid == request.auth.uid);
      allow write: if isAdminOrCoach()
        || (isParent()
            && request.resource.data.parentUid == request.auth.uid
            && request.resource.data.studentId in ownStudentIds());
    }

    // Mazeret/izin talepleri: personel hepsini okur ve durumunu (Onaylandı/
    // Reddedildi) günceller. Veli yalnızca kendi çocuğu için "Beklemede" bir
    // talep oluşturur, kendi taleplerini okur ve iptal için silebilir; başka
    // kimsenin talebine erişemez ve durumu kendisi değiştiremez.
    match /leaveRequests/{document} {
      allow read: if isStaff()
        || (isParent() && resource.data.parentUid == request.auth.uid);
      allow create: if isParent()
        && request.resource.data.parentUid == request.auth.uid
        && request.resource.data.studentId in ownStudentIds()
        && request.resource.data.status == "Beklemede";
      allow update: if isAdminOrCoach();
      allow delete: if isAdmin()
        || (isParent() && resource.data.parentUid == request.auth.uid);
    }

    // Kulüp kasası (gelir/gider defteri): kulübün nakit hareketleri hassas
    // olduğundan yalnızca admin okur ve yazar. Antrenör/veli erişemez.
    match /cashTransactions/{document} {
      allow read, write: if isAdmin();
    }

    // Depo / ekipman envanteri: personel görür; admin/antrenör düzenler.
    match /equipment/{document} {
      allow read: if isStaff();
      allow write: if isAdminOrCoach();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
