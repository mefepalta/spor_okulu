rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && role() == "admin";
    }

    function isCoach() {
      return isSignedIn() && role() == "coach";
    }

    function isParent() {
      return isSignedIn() && role() == "veli";
    }

    function isAdminOrCoach() {
      return isAdmin() || isCoach();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == "viewer";
      allow update, delete: if isAdmin();
    }

    match /students/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coaches/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /groups/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /payments/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /attendanceRecords/{document} {
      allow read: if isSignedIn();
      allow write: if isAdminOrCoach();
    }

    match /announcements/{document} {
      allow read: if isSignedIn();
      allow write: if isAdminOrCoach();
    }

    // Antrenör/admin performans girer; herkes (veliler dahil) okuyabilir.
    match /performanceRecords/{document} {
      allow read: if isSignedIn();
      allow write: if isAdminOrCoach();
    }

    // Antrenör/admin etkinlik planlar; herkes okuyabilir.
    match /plannedEvents/{document} {
      allow read: if isSignedIn();
      allow write: if isAdminOrCoach();
    }

    // Veliler kendi katılım cevaplarını yazabilir; antrenör/admin hepsini
    // görüp yönetebilir.
    match /eventResponses/{document} {
      allow read: if isSignedIn();
      allow write: if isAdminOrCoach()
        || (isParent()
            && request.resource.data.parentUid == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
